    <title>termux数据备份与恢复</title>
    <link href="/2023/12/20/termux%E6%95%B0%E6%8D%AE%E4%B8%8E%E6%81%A2%E5%A4%8D/"/>
    <url>/2023/12/20/termux%E6%95%B0%E6%8D%AE%E4%B8%8E%E6%81%A2%E5%A4%8D/</url>
    
    <content type="html"><![CDATA[<h1 id="授权"><a href="#授权" class="headerlink" title="授权"></a>授权</h1><div class="code-wrapper"><pre><code class="hljs bash">$ termux-setup-storage</code></pre></div><h3 id="切换目录"><a href="#切换目录" class="headerlink" title="切换目录"></a>切换目录</h3><div class="code-wrapper"><pre><code class="hljs bash">$ <span class="hljs-built_in">cd</span> /data/data/com.termux/files</code></pre></div><h3 id="备份到Download"><a href="#备份到Download" class="headerlink" title="备份到Download"></a>备份到Download</h3><div class="code-wrapper"><pre><code class="hljs bash">$ tar -zcf /sdcard/Download/termux-backup.tar.gz home usr</code></pre></div><h1 id="恢复"><a href="#恢复" class="headerlink" title="恢复"></a>恢复</h1><h3 id="切换目录-1"><a href="#切换目录-1" class="headerlink" title="切换目录"></a>切换目录</h3><div class="code-wrapper"><pre><code class="hljs bash">$ <span class="hljs-built_in">cd</span> /data/data/com.termux/files</code></pre></div><h3 id="从Download恢复"><a href="#从Download恢复" class="headerlink" title="从Download恢复"></a>从Download恢复</h3><div class="code-wrapper"><pre><code class="hljs bash">$ tar -zxf /sdcard/Download/termux-backup.tar.gz --recursive-unlink --preserve-permissions</code></pre></div>]]></content>
    
    
